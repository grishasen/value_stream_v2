.DS_Store

# Obsidian: the shared docs vault config is tracked; per-user UI state is not
docs/.obsidian/workspace.json

# Project transient
*.duckdb
*.duckdb.wal

# R cruft (the original directory had .Rhistory; keep it ignored going forward)
.Rhistory

# MkDocs build output
site/

# Claude Code per-user harness state (shared `.claude/settings.json` is fine to commit)
.claude/settings.local.json
/examples/*
!/examples/demo/
/examples/demo/*
!/examples/demo/ai.yaml
!/examples/demo/ai_gpt.yaml
# Track the demo catalog so tests/CI can load it on a clean checkout; the
# large data/, aggregates/, and meta/ folders stay ignored and are rebuilt
# by the test data generator (see tests/conftest.py).
!/examples/demo/catalog/
# Track the catalog-only FAT migration showcase while keeping any local source
# exports and generated workspace state ignored.
!/examples/fat/
/examples/fat/*
!/examples/fat/README.md
!/examples/fat/catalog/
/.claude/
/artifacts/
/.agents/
/examples/fat/
